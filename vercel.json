{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/market-rates/latest", "destination": "/api/public?route=market-rates/latest" },
    { "source": "/api/ocr-snapshot/latest", "destination": "/api/public?route=ocr-snapshot/latest" },
    { "source": "/api/adviser-review-request", "destination": "/api/public?route=adviser-review-request" },
    { "source": "/api/analytics/event", "destination": "/api/public?route=analytics/event" },
    { "source": "/api/admin/(.*)", "destination": "/api/admin?path=$1" },
    { "source": "/api/cron/(.*)", "destination": "/api/cron?job=$1" },
    { "source": "/admin", "destination": "/api/admin?path=page" },
    { "source": "/calculator", "destination": "/index.html" },
    { "source": "/info", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/privacy-policy", "destination": "/index.html" },
    { "source": "/terms-of-use", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/refresh-market-rates", "schedule": "0 3 * * *" },
    { "path": "/api/cron/refresh-ocr-snapshot", "schedule": "15 3 * * *" }
  ],
  "functions": {
    "api/cron.js": { "maxDuration": 30 },
    "api/admin.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}

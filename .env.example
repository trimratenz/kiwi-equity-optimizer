VITE_API_BASE_URL=
# development | preview | production. Vercel automatically supplies VERCEL_ENV, but set this locally.
TRIMRATE_ENV=development
# Keep false for local and Preview unless they use an isolated non-production Supabase project.
TRIMRATE_ALLOW_NONPROD_WRITES=false
# Production-only escape hatch for authenticated admin access to /admin/test.
ADMIN_TEST_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
CRON_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

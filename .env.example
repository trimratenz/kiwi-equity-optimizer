VITE_API_BASE_URL=
# development | preview | production. Vercel automatically supplies VERCEL_ENV, but set this locally.
TRIMRATE_ENV=development
# Keep false for local and Preview so analytics and lead details are not stored.
TRIMRATE_ALLOW_NONPROD_WRITES=false
# Production-only escape hatch for authenticated admin access to /admin/test.
ADMIN_TEST_ENABLED=false
# Google Apps Script Web App URL and a long random secret shared only with the
# script's Script Properties. These are server-side Vercel variables.
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
CRON_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
